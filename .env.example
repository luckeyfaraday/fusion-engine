# --- Fusion Engine configuration -------------------------------------------
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
# `.env` is git-ignored; never commit real keys.

# REQUIRED. OpenRouter API key. Create one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Panel used when --panel/-p is not passed on the CLI (budget | quality | code)
FUSION_DEFAULT_PANEL=budget

# Logging verbosity (DEBUG | INFO | WARNING | ERROR)
FUSION_LOG_LEVEL=INFO

# Optional. Protect HTTP endpoints that spend OpenRouter credits.
# If set, clients must send: Authorization: Bearer <this value>
FUSION_SERVER_API_KEY=

# Optional OpenRouter attribution headers.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Fusion Engine
